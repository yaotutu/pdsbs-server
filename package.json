{
  "name": "pdsbs-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node -e \"require('dotenv').config();const{execSync}=require('child_process');execSync('next start -p '+(process.env.PORT||3000),{stdio:'inherit'})\"",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "db:push": "npx prisma db push",
    "db:seed": "npm run db:push && npm run seed",
    "db:reset": "npx prisma db push --force-reset && npm run seed"
  },
  "dependencies": {
    "@ant-design/pro-components": "^2.8.10",
    "@base-ui/react": "^1.3.0",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tinymce/tinymce-react": "^6.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "formidable": "^3.5.4",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tinymce": "^8.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/formidable": "^3.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}

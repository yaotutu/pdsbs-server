DATABASE_URL=file:./dev.db
JWT_SECRET=your-secret-key
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret
APP_URL=http://your-server-address:3000

# 开启后小程序端按游客访问，不触发微信授权，文章详情不校验登录
GUEST_ACCESS_ENABLED=false

# 京东云 OSS
OSS_ENDPOINT=https://s3.cn-north-1.jcloudcs.com
OSS_REGION=cn-north-1
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_SECRET_ACCESS_KEY=your-secret-access-key
OSS_BUCKET=your-bucket-name
OSS_CDN_DOMAIN=
